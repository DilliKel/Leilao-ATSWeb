# URL do servidor Socket.io (backend/), usada pelo frontend em app/socket.ts
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Banco de dados SQLite de autenticação (usuários/senhas), criado por `npx prisma migrate dev`
DATABASE_URL="file:./dev.db"

# URL pública do próprio frontend, exigida pelo NextAuth
NEXTAUTH_URL=http://localhost:3001

# Segredo usado pelo NextAuth para assinar sessão/JWT — gere um valor único com `openssl rand -base64 32`
NEXTAUTH_SECRET=

# Segredo compartilhado com backend/.env (mesma chave nos dois lados) para assinar o token
# que autentica a conexão do Socket.io — gere com `openssl rand -base64 32`
SOCKET_JWT_SECRET=
