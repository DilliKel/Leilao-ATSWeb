# Porta em que o servidor Socket.io escuta
PORT=3000

# Origem liberada no CORS para conectar ao servidor (URL do frontend Next.js)
CORS_ORIGIN=http://localhost:3001

# Banco de dados SQLite (arquivo local, criado por `npx prisma migrate dev`)
DATABASE_URL="file:./dev.db"

# Segredo compartilhado com o .env da raiz (mesma chave nos dois lados) para validar o token
# que autentica a conexão do Socket.io — deve ser IDÊNTICO ao SOCKET_JWT_SECRET do frontend
SOCKET_JWT_SECRET=
